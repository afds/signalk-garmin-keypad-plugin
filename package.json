{
  "name": "signalk-garmin-keypad-plugin",
  "version": "1.0.5",
  "description": "Signal K plugin for GNX Keypad control on NMEA 2000",
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run build:webapp",
    "build:plugin": "tsc",
    "build:webapp": "cd webapp && npm run build",
    "watch": "tsc -w",
    "test": "tsc && mocha --exit"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-nmea-2000",
    "signalk-embeddable-webapp"
  ],
  "signalk": {
    "displayName": "GNX Keypad"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/afds/signalk-garmin-keypad-plugin.git"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@signalk/server-api": "^2.24.0"
  },
  "devDependencies": {
    "@canboat/canboatjs": "^3.3.0",
    "@types/node": "^24.12.2",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "typescript": "^6.0.2"
  }
}
