{
  "name": "signalk-garmin-keypad",
  "version": "1.0.0",
  "description": "Signal K plugin for Garmin GNX Keypad control on NMEA 2000",
  "main": "index.js",
  "scripts": {
    "build": "tsc && cd webapp && npm run build",
    "build:plugin": "tsc",
    "build:webapp": "cd webapp && npm run build",
    "watch": "tsc -w",
    "test": "tsc && mocha --exit"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-nmea-2000",
    "signalk-embeddable-webapp"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@signalk/server-api": "^1.39.0"
  },
  "devDependencies": {
    "@canboat/canboatjs": "^3.3.0",
    "@types/debug": "^4.1.13",
    "@types/node": "^14.14.10",
    "chai": "^4.1.2",
    "mocha": "^5.0.0",
    "typescript": "^4.1.2"
  }
}
